{
  "manifest_version": 3,
  "name": "Unskippable Climate",
  "version": "1.0.0",
  "description": "Adds a rotating climate fact to every email you send.",
  "action": {
    "default_popup": "popup.html",
    "default_title": "Unskippable Climate"
  },
  "permissions": ["storage"],
  "host_permissions": [
    "https://mail.google.com/*",
    "https://unskippable.climate/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://mail.google.com/*"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
